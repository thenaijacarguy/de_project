),

cleaned AS (
    SELECT
        TRIM(order_id)                         AS order_id,
        TRIM(LOWER(customer_id))               AS customer_id,
        CAST(order_date AS DATE)               AS order_date,

        -- Normalise status to lowercase and remove any test/internal orders.
